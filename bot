        user_data["state"] = "await_session_type"
        await update.effective_message.reply_text(texts.ASK_SESSION_TYPE)
        return

    if state == "await_session_type":
        if not text:
            await update.effective_message.reply_text("횢혛횢혞횠쨔 횠짠횢혙횠짭횢혙횠쨀횠짤 횢혙횠짠 횢혡횢혚횢혘횢혛 횠짙횢혛 횢혡횢혘횢혞횢혛 횢혖횠짠횠짹횠쨘횢혢횠짠. 횠짙횠쨔횠짱 횠짠횢혙횢혚횠짯횠짠횢혞횢혙횠짤:")
