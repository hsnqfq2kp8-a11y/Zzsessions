        return

    if state == "await_telegram":
        if not text:
            await update.effective_message.reply_text("횠짠횢혙횢혚횠쨔횠짹횢혖 횢혙횠짠 횢혡횢혚횢혘횢혛 횠짙횢혛 횢혡횢혘횢혞횢혛 횢혖횠짠횠짹횠쨘횢혢횠짠. 횠짙횠쨔횠짱 횠짠횢혙횢혚횠짯횠짠횢혞횢혙횠짤:")
            return
